{
  "compilerOptions": {
    /* Базовые опции для ESM */
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".", // Меняем на текущую папку (server)
    "baseUrl": ".",

    /* Настройки модулей */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Пути для импортов */
    "paths": {
      "@/*": ["./*"],
      "@src/*": ["src/*"],
      "@tests/*": ["tests/*"],
      "@shared/*": ["../packages/shared/*"]
    },

    /* Настройки для работы с типами */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],

    /* Настройки для компиляции */
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "types/**/*",
    "../packages/shared/**/*"
  ],
  "exclude": ["node_modules", "dist", "../packages/shared/node_modules"]
}
